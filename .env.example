# База данных PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=electro_db

# Backend настройки
DEBUG=False
SECRET_KEY=your_secret_key_here_change_this_to_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend URL (для CORS)
# Для development: http://localhost
# Для production: https://your-domain.com
FRONTEND_URL=http://localhost

# Порт для фронтенда (по умолчанию 80)
# Если используете nginx-proxy, оставьте 80
FRONTEND_PORT=80

# Суперпользователь (опционально, для создания при запуске)
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=admin_password
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PLOT_NUMBER=1

# SSL/HTTPS настройки (для production с docker-compose.prod.yml)
# Email для Let's Encrypt уведомлений (обязательно для production)
LETSENCRYPT_EMAIL=admin@example.com

# Домен для SSL сертификата (обязательно для production)
# Укажите ваш купленный домен без http:// и https://
# Например: myelectro.com или electro.mydomain.ru
VIRTUAL_HOST=your-domain.com
LETSENCRYPT_HOST=your-domain.com
