# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/electro_db

# JWT Configuration
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Configuration
FRONTEND_URL=http://localhost:3000

# Superuser Configuration (optional - for create-superuser command)
# Uncomment and set these values to create superuser without prompts
# SUPERUSER_USERNAME=admin
# SUPERUSER_PASSWORD=admin123
# SUPERUSER_EMAIL=admin@example.com
# SUPERUSER_PLOT_NUMBER=ADMIN-001
